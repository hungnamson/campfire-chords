{
  "name": "campfire-chords",
  "version": "1.9.0",
  "description": "Offline Lyrics & Chords Guitar App for Campfires",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "node server.js",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix frontend",
    "install-all": "npm install && npm install --prefix frontend"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "got-scraping": "^4.2.1",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
